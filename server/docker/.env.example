# SwimEx EDGE — Docker environment variables
# Copy this file to .env and set your own values before running docker compose up.
#
# REQUIRED on first run (used to create the initial admin account):
ADMIN_USER=admin
ADMIN_PASS=
SUPERADMIN_PASS=

# MQTT credentials (used by the embedded broker and MQTT client):
MQTT_USER=edge-server
MQTT_PASS=

# JWT secret (sessions won't survive restarts without this):
JWT_SECRET=
